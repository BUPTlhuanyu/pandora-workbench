{
    "name": "pandora-workbench",
    "version": "1.0.0",
    "description": "The workbench for coder",
    "private": true,
    "scripts": {
        "clean:release": "rm -rf ./packages/workbench-electron/release",
        "clean:app": "rm -rf ./packages/workbench-electron/app/dist",
        "cp:dist": "cp -r ./packages/views/dist/* ./packages/workbench-electron/app/dist",
        "start:workbench": "pnpm --filter workbench-electron start",
        "start:views": "pnpm --filter views start",
        "start:views-web": "pnpm --filter views start:web",
        "build:views": "pnpm --filter views build",
        "build:views-web": "pnpm --filter views build:web",
        "build:workbench-electron": "pnpm --filter workbench-electron build",
        "build:mac": "pnpm --filter workbench-electron build:mac",
        "release:mac": "pnpm --filter workbench-electron release:mac",
        "lint": "eslint 'packages/**/*.{ts,tsx,js,jsx}'",
        "prepare": "husky"
    },
    "files": [
        "packages"
    ],
    "devDependencies": {
        "@commitlint/cli": "^19.0.0",
        "@commitlint/config-conventional": "^19.0.0",
        "@types/node": "^20.0.0",
        "@typescript-eslint/eslint-plugin": "^8.0.0",
        "@typescript-eslint/parser": "^8.0.0",
        "commitizen": "^4.3.0",
        "cz-conventional-changelog": "^3.3.0",
        "eslint": "^8.57.0",
        "eslint-plugin-react": "^7.37.0",
        "eslint-plugin-react-hooks": "^5.0.0",
        "husky": "^9.0.0",
        "lint-staged": "^15.0.0",
        "typescript": "^5.5.0"
    },
    "lint-staged": {
        "!(example|dist|output|__mocks__)/**/*.(ts|tsx|js|jsx)": [
            "eslint --fix"
        ]
    },
    "config": {
        "commitizen": {
            "path": "./node_modules/cz-conventional-changelog"
        }
    },
    "repository": {
        "type": "git",
        "url": "git://github.com/BUPTlhuanyu/pandora-workbench"
    },
    "author": "lhuanyu <lhuanyutot@163.com>",
    "license": "MIT",
    "packageManager": "pnpm@9.15.4",
    "engines": {
        "node": ">=18.0.0"
    }
}

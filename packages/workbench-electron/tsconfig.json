{
    "compilerOptions": {
        "target": "ES2021",
        "module": "CommonJS",
        "lib": ["ES2021"],
        "outDir": "./app/dist",
        "strict": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "moduleResolution": "node",
        "experimentalDecorators": true
    },
    "include": ["main/**/*", "../services/**/*", "../core/**/*", "../shared/**/*"],
    "exclude": ["node_modules", "app", "release"]
}
